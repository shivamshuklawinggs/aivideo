# Application
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000

# Database
MONGODB_URI=mongodb://127.0.0.1:27017/webtoon_explainer

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=redis123

# RabbitMQ
RABBITMQ_URL=amqp://admin:admin123@localhost:5672

# MinIO (S3-compatible storage)
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123
MINIO_BUCKET_NAME=webtoon-storage

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRE=7d
JWT_REFRESH_SECRET=your-super-secret-refresh-key-change-this
JWT_REFRESH_EXPIRE=30d

# AI Services Configuration
SYSTEM_RAM_GB=16

# Ollama (Local AI Service)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3:8b
OLLAMA_VISION_MODEL=llava:7b

# OpenAI
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_ORG_ID=your-openai-org-id-here

# Cohere
COHERE_API_KEY=your-cohere-api-key-here

# HuggingFace
HUGGINGFACE_API_KEY=your-huggingface-api-key-here

# Replicate
REPLICATE_API_TOKEN=your-replicate-api-token-here

# Together AI
TOGETHERAI_API_KEY=your-togetherai-api-key-here

# AI Model Configuration
MAX_CONCURRENT_MODELS=2
MODEL_UNLOAD_TIMEOUT=300000
MEMORY_THRESHOLD_GB=16

# XTTS Voice Cloning
XTTS_API_URL=http://localhost:8000
XTTS_MODEL_PATH=./models/xtts

# Whisper
WHISPER_MODEL=base

# File Upload
MAX_FILE_SIZE=500000000
ALLOWED_ARCHIVE_TYPES=.cbz,.cbr,.zip
ALLOWED_AUDIO_TYPES=.wav,.mp3,.flac

# Video Processing
FFMPEG_PATH=/usr/bin/ffmpeg
VIDEO_OUTPUT_DIR=./storage/videos
TEMP_DIR=./temp

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Logging
LOG_LEVEL=info
LOG_FILE=./logs/app.log

# Email (Optional - for notifications)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Sentry (Optional - for error tracking)
SENTRY_DSN=

# Analytics (Optional)
GOOGLE_ANALYTICS_ID=
